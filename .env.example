# Copy to .env and fill in values from the Neon console.
DATABASE_URL=postgresql://neondb_owner:PASSWORD@HOST/neondb?sslmode=require
SECRET_KEY=change-me
DEBUG=true
# Localhost-only marketing page edits that write into templates/. Keep false on live.
SIAW_SITE_EDIT=true
# Demo account shown and prefilled on the login form.
SIAW_DEMO_USERNAME=demo
SIAW_DEMO_PASSWORD=siawdemo123
SIAW_DEMO_EMAIL=demo@siaw.local

# AI Builder. auto = Codex if installed, else OpenAI key, else offline.
# Ollama is disabled (local model loads can freeze the host).
SIAW_AI_PROVIDER=auto
SIAW_AI_MODEL=gpt-5.6-sol
# Optional OpenAI fallback when Codex is unavailable.
# OPENAI_API_KEY=
# SIAW_AI_API_KEY=
SIAW_AI_TIMEOUT_SECONDS=0
SIAW_AI_FORCE_OFFLINE=false
SIAW_CODEX_MODEL=gpt-5.6-sol
SIAW_CODEX_TIMEOUT_SECONDS=900

# Shopify merchant app (Partners). Merchants install from Shopify Admin.
# Leave blank to hide Shopify UI until credentials exist.
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_API_VERSION=2025-10
# SHOPIFY_SCOPES=read_products,read_product_listings,read_files,read_themes
# Public https origin (App URL = {SHOPIFY_APP_URL}/shopify/app/). No trailing slash.
# SHOPIFY_APP_URL=https://your-tunnel.example
